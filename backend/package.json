{
	"name": "website-alerter-backend",
	"version": "1.0.0",
	"author": "PickySalamander",
	"license": "MIT",
	"scripts": {
		"build:local": "tsc -noEmit && cdk synth --context config=local --no-staging --quiet && sam build -t cdk.out/WebsiteAlerter.template.json",
		"start:process": "npx tsx --env-file=process.env src/process/process-sites.ts",
		"test": "vitest",
		"clean": "rimraf cdk.out build .aws-sam .durable-executions-local",
		"deploy": "tsc -noEmit && cdk deploy --quiet --require-approval never",
		"deploy:prompt": "aws s3 cp prompt/schema.json s3://website-alerter-468451602170/prompt/ && aws s3 cp prompt/system-prompt.txt s3://website-alerter-468451602170/prompt/",
		"synth": "cdk synth"
	},
	"devDependencies": {
		"@aws-sdk/client-bedrock-runtime": "^3.1000.0",
		"@aws-sdk/client-dynamodb": "^3.1000.0",
		"@aws-sdk/client-s3": "^3.1000.0",
		"@aws-sdk/client-sns": "^3.1000.0",
		"@aws-sdk/client-sqs": "^3.1000.0",
		"@aws-sdk/lib-dynamodb": "^3.1000.0",
		"@types/aws-lambda": "^8.10.161",
		"@types/http-errors": "^2.0.5",
		"aws-cdk": "^2.1108.0",
		"esbuild": "^0.27.3"
	},
	"dependencies": {
		"@aws-sdk/s3-request-presigner": "^3.1000.0",
		"@aws/durable-execution-sdk-js": "^1.0.2",
		"@middy/core": "^7.1.2",
		"@middy/error-logger": "^7.1.2",
		"@middy/http-cors": "^7.1.2",
		"@middy/http-error-handler": "^7.1.2",
		"@middy/http-header-normalizer": "^7.1.2",
		"@middy/http-json-body-parser": "^7.1.2",
		"aws-cdk-lib": "^2.240.0",
		"console-stamp": "^3.1.2",
		"constructs": "^10.5.1",
		"handlebars": "^4.7.9",
		"http-errors": "^2.0.1",
		"puppeteer": "^24.42.0",
		"source-map-support": "^0.5.21"
	}
}
