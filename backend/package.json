{
	"name": "website-alerter-backend",
	"version": "1.0.0",
	"author": "PickySalamander",
	"license": "MIT",
	"scripts": {
		"build:local": "tsc -noEmit && cdk synth --context config=local --no-staging --quiet",
		"build:process": "npm run build:local && sam build -t cdk.out/WebsiteAlerter.template.json",
		"start:local": "npm run build:local && sam local start-api --warm-containers LAZY -n env.json -t cdk.out/WebsiteAlerter.template.json --profile $AWS_PROFILE",
		"test": "vitest --passWithNoTests",
		"clean": "rimraf cdk.out build .aws-sam .durable-executions-local",
		"deploy": "tsc -noEmit && cdk deploy --quiet --require-approval never",
		"deploy:prompt": "aws s3 cp prompt/schema.json s3://website-alerter-468451602170/prompt/ && aws s3 cp prompt/system-prompt.txt s3://website-alerter-468451602170/prompt/",
		"synth": "cdk synth"
	},
	"devDependencies": {
		"@aws-sdk/client-bedrock-runtime": "^3.1036.0",
		"@aws-sdk/client-dynamodb": "^3.1036.0",
		"@aws-sdk/client-s3": "^3.1036.0",
		"@aws-sdk/client-sns": "^3.1036.0",
		"@aws-sdk/client-sqs": "^3.1036.0",
		"@aws-sdk/lib-dynamodb": "^3.1036.0",
		"@types/aws-lambda": "^8.10.161",
		"@types/http-errors": "^2.0.5",
		"aws-cdk": "^2.1119.0",
		"esbuild": "^0.28.0"
	},
	"dependencies": {
		"@aws-sdk/s3-request-presigner": "^3.1036.0",
		"@aws/durable-execution-sdk-js": "^1.1.1",
		"@middy/core": "^7.3.2",
		"@middy/error-logger": "^7.3.2",
		"@middy/http-cors": "^7.3.2",
		"@middy/http-error-handler": "^7.3.2",
		"@middy/http-header-normalizer": "^7.3.2",
		"@middy/http-json-body-parser": "^7.3.2",
		"aws-cdk-lib": "^2.250.0",
		"console-stamp": "^3.1.2",
		"constructs": "^10.6.0",
		"handlebars": "^4.7.9",
		"http-errors": "^2.0.1",
		"puppeteer": "^24.42.0",
		"source-map-support": "^0.5.21"
	}
}
